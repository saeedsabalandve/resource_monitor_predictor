# ============================================
# Server Configuration
# ============================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG_MODE=false
LOG_LEVEL=INFO

# ============================================
# Database Configuration
# ============================================
# InfluxDB for time-series metrics
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your_influxdb_token_here
INFLUXDB_ORG=your_organization
INFLUXDB_BUCKET=resource_metrics

# PostgreSQL for metadata and configuration
DATABASE_URL=postgresql://monitor:password@localhost:5432/resource_monitor

# Redis for caching and task queue
REDIS_URL=redis://localhost:6379/0

# ============================================
# Security Configuration
# ============================================
SECRET_KEY=your_secret_key_here_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600
API_KEY=your_api_key_here

# ============================================
# Collection Intervals (in seconds)
# ============================================
CPU_COLLECTION_INTERVAL=10
MEMORY_COLLECTION_INTERVAL=10
DISK_COLLECTION_INTERVAL=60
NETWORK_COLLECTION_INTERVAL=30
PROCESS_COLLECTION_INTERVAL=120

# ============================================
# Prediction Configuration
# ============================================
PREDICTION_HORIZON_HOURS=24
PREDICTION_INTERVAL_MINUTES=15
RETRAIN_INTERVAL_HOURS=24
MIN_DATA_POINTS_FOR_PREDICTION=100

# Prediction Methods (comma-separated)
# Available: arima,prophet,lstm,exponential_smoothing,linear_regression
ACTIVE_PREDICTION_METHODS=arima,prophet,exponential_smoothing

# ============================================
# Alert Configuration
# ============================================
CPU_THRESHOLD_PERCENT=90
MEMORY_THRESHOLD_PERCENT=85
DISK_THRESHOLD_PERCENT=90
ALERT_COOLDOWN_MINUTES=30

# Notification channels (comma-separated)
# Available: email,slack,webhook
ALERT_CHANNELS=email,slack

# Email settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@yourcompany.com
SMTP_PASSWORD=your_email_password

# Slack webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# ============================================
# Performance Configuration
# ============================================
MAX_WORKERS=4
CACHE_TTL_SECONDS=300
BATCH_SIZE=1000
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60
